{
  "title": "عدالة AI — Overview",
  "uid": "adala-overview",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "معدل الطلبات (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "rate(adala_http_requests_total[1m])", "legendFormat": "req/s" }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2, "type": "stat", "title": "متوسط زمن الاستجابة (ms)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "rate(adala_http_request_duration_ms_sum[1m]) / rate(adala_http_request_duration_ms_count[1m])", "legendFormat": "avg ms" }],
      "options": { "colorMode": "background", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 1000 }] } }
    },
    {
      "id": 3, "type": "stat", "title": "معدل الأخطاء (errors/s)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "rate(adala_http_errors_total[1m])", "legendFormat": "errors/s" }],
      "options": { "colorMode": "background", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.1 }] } }
    },
    {
      "id": 4, "type": "stat", "title": "صحة قاعدة البيانات",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "adala_db_health", "legendFormat": "DB" }],
      "options": { "colorMode": "background", "mappings": [{ "options": { "0": { "text": "⛔ Down" }, "1": { "text": "✅ Healthy" } }, "type": "value" }] }
    },
    {
      "id": 5, "type": "timeseries", "title": "HTTP Requests Rate",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(adala_http_requests_total{status=~'2..'}[1m])", "legendFormat": "2xx" },
        { "expr": "rate(adala_http_requests_total{status=~'4..'}[1m])", "legendFormat": "4xx" },
        { "expr": "rate(adala_http_requests_total{status=~'5..'}[1m])", "legendFormat": "5xx" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Response Time Percentiles (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(adala_http_request_duration_ms_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(adala_http_request_duration_ms_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(adala_http_request_duration_ms_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "AI Requests",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(adala_ai_requests_total[5m])", "legendFormat": "{{type}} / {{model}}" }]
    },
    {
      "id": 8, "type": "timeseries", "title": "Node.js Memory (MB)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "adala_node_process_resident_memory_bytes / 1024 / 1024", "legendFormat": "RSS (MB)" },
        { "expr": "adala_node_nodejs_heap_size_used_bytes / 1024 / 1024", "legendFormat": "Heap Used (MB)" },
        { "expr": "adala_node_nodejs_heap_size_total_bytes / 1024 / 1024", "legendFormat": "Heap Total (MB)" }
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "PostgreSQL Connections",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [{ "expr": "pg_stat_activity_count", "legendFormat": "connections" }]
    },
    {
      "id": 10, "type": "timeseries", "title": "Redis Memory Used (MB)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [{ "expr": "redis_memory_used_bytes / 1024 / 1024", "legendFormat": "Redis MB" }]
    }
  ]
}
