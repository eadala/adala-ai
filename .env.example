# ══════════════════════════════════════════════════════════
#  عدالة AI — متغيرات البيئة
#  انسخ هذا الملف إلى .env وعدّل القيم
#  هذا الملف آمن للرفع على GitHub (لا يحتوي على أسرار)
# ══════════════════════════════════════════════════════════

# ── معلومات التطبيق ────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_VERSION=1.0.0
# عنوان النطاق العام للتطبيق (callbacks, webhooks, emails)
PRODUCTION_URL=https://adalahai.com
# بديل اختياري لـ PRODUCTION_URL
APP_URL=

# ── قاعدة البيانات ──────────────────────────────────────
# Hetzner Managed DB أو PostgreSQL عادي
DATABASE_URL=postgresql://user:password@host:5432/adala

# ── Clerk (المصادقة) ────────────────────────────────────
# احصل عليها من: https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
# مسار بروكسي Clerk — يُضبط تلقائياً عند النشر (مثال: /api/__clerk)
# اتركه فارغاً في التطوير المحلي — التطبيق يتصل مباشرة بـ clerk.accounts.dev
VITE_CLERK_PROXY_URL=

# ── السوبر أدمن ────────────────────────────────────────
PLATFORM_OWNER_EMAIL=your-email@domain.com

# ── خدمات الذكاء الاصطناعي السحابية ──────────────────
# على الأقل واحدة مطلوبة (Gemini موصى به)
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (النموذج المحلي — اختياري) ─────────────────
# عنوان Ollama على نفس الشبكة (Docker) أو على نفس الجهاز
OLLAMA_BASE_URL=http://ollama:11434
# النموذج المُستخدم (gemma3:4b مناسب لـ 4GB RAM)
OLLAMA_MODEL=gemma3:4b
# تفعيل Ollama كاحتياطي تلقائي إذا فشلت الخدمات السحابية
OLLAMA_FALLBACK_ENABLED=true

# ── بوابة الدفع — Moyasar (أساسي) ─────────────────────
PAYMENT_PROVIDER=moyasar
MOYASAR_SECRET_KEY=
MOYASAR_PUBLISHABLE_KEY=
# اختياري — للتحقق من توقيع webhooks
MOYASAR_WEBHOOK_SECRET=

# ── Stripe (اختياري — معطّل افتراضياً) ─────────────────
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ── النشر والـ CI/CD ────────────────────────────────────
# تُضبط تلقائياً من Coolify أو GitHub Actions
GITHUB_REPOSITORY=eadala/adala-ai
GITHUB_TOKEN=
GITHUB_SHA=
GITHUB_REF_NAME=main
DEPLOYMENT_TIMESTAMP=

# ── البريد الإلكتروني (اختياري) ───────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── التشفير والأمان ────────────────────────────────────
# مفتاح عشوائي 32 حرفاً (openssl rand -hex 32)
SESSION_SECRET=change_me_to_random_64_char_string

# ── التخزين السحابي — Cloudflare R2 ─────────────────────
STORAGE_PROVIDER=cloudflare_r2
R2_BUCKET_NAME=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# اختياري — بادئة الملفات الخاصة (افتراضي: private)
# PRIVATE_OBJECT_DIR=/bucket-name/private
# PUBLIC_OBJECT_SEARCH_PATHS=/bucket-name/public
# مفتاح تشفير النسخ الاحتياطية (openssl rand -hex 32)
BACKUP_ENCRYPTION_KEY=

# ── الإشعارات ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
