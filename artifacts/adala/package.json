    "governance:audit": "node ../../scripts/governance/ui-audit.mjs",
    "governance:audit:json": "node ../../scripts/governance/ui-audit.mjs --json",
    "validate:routes": "node scripts/validate-routes.mjs",
    "validate:platform": "node ../../scripts/governance/platform-check.mjs",
    "test:auth-fetch-migration": "pnpm --dir ../api-server exec tsx ../adala/src/tests/authFetchMigrationComplete.test.ts"
