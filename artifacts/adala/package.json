    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:auth-fetch": "pnpm --dir ../api-server exec tsx ../adala/src/tests/authFetch.test.ts",
    "test:create-routes": "pnpm --dir ../api-server exec tsx ../adala/src/tests/createRoutes.test.ts",
    "test:documents-create-folder": "pnpm --dir ../api-server exec tsx ../adala/src/tests/documentsCreateFolder.test.ts",
