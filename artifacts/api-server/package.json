{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "lint": "eslint src --max-warnings=9999",
    "lint:fix": "eslint src --fix --max-warnings=9999",
    "start": "node --max-old-space-size=512 --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:storage": "node --import tsx --test src/tests/r2-storage.test.ts",
    "test:storage-office-id": "node --import tsx src/tests/storageOfficeId.test.ts",
    "test:storage-file-register": "node --import tsx src/tests/storageFileRegister.test.ts",
    "test:storage-folder-create": "node --import tsx src/tests/storageFolderCreate.test.ts",
    "test:tenant-fallback-removal": "node --import tsx src/tests/tenantFallbackRemoval.test.ts",
    "test:tenant-gated-writes": "node --import tsx src/tests/tenantGatedWrites.test.ts",
    "test:post-migration": "node --import tsx src/tests/postMigrationApiFixes.test.ts",
    "test:offices-my": "node --import tsx src/tests/officesMy.test.ts",
    "test:metrics-vitals": "node --import tsx src/tests/metricsBeaconPath.test.ts && node --import tsx src/tests/metricsVitals.integration.test.ts",
    "test:cors-origin": "node --import tsx src/tests/corsOriginPolicy.test.ts",
    "test:payments-error-swallowing": "node --import tsx src/tests/paymentsErrorSwallowing.test.ts",
    "test:schema-authority": "node --import tsx src/tests/schemaAuthority.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/s3-request-presigner": "^3.1080.0",
    "@clerk/express": "^2.1.22",
    "@clerk/shared": "^4.14.0",
    "@google-cloud/storage": "^7.19.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation": "^0.219.0",
    "@opentelemetry/instrumentation-express": "^0.67.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-pg": "^0.71.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/node": "^10.58.0",
    "@types/compression": "^1.8.1",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "axios": "^1.17.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^4.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.10",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/web-push": "^3.6.4",
    "esbuild": "0.28.1",
    "esbuild-plugin-pino": "^2.3.3",
    "eslint": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "^4.22.4",
    "typescript-eslint": "^8.61.1"
  }
}
